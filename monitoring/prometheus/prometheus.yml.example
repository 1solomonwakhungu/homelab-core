global:
  scrape_interval: 30s
  evaluation_interval: 30s
  external_labels:
    environment: homelab
    source: homelab-core-example

rule_files:
  - alerts/*.rules.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - 127.0.0.1:9090
        labels:
          service: prometheus

  - job_name: node-exporter-placeholder
    metrics_path: /metrics
    static_configs:
      - targets:
          - node-exporter.internal.example:9100
        labels:
          service: node-exporter
          criticality: medium

  - job_name: homelab-service-placeholder
    metrics_path: /metrics
    static_configs:
      - targets:
          - service.internal.example:9100
        labels:
          service: placeholder-service
          criticality: todo
